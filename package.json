{
  "name": "wishlist",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "check": "prettier --check './**/*.{html,css,js}'",
    "format": "prettier --write './**/*.{html,css,js}'",
    "lint": "stylelint '**/*.css'",
    "lintfix": "stylelint '**/*.css' --fix",
    "eslint": "eslint src",
    "eslintfix": "eslint --fix src",
    "checkAll": "npm run check && npm run lint && npm run eslint",
    "fixAll": "npm run format && npm run lintfix && npm run eslintfix",
    "dev": "vite",
    "build": "vite build"
  },
  "dependencies": {
    "lucide-react": "^1.7.0",
    "prettier": "^3.8.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "stylelint": "^17.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "eslint": "^9.30.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "vite": "^7.0.4"
  }
}
