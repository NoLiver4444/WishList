{
  "name": "wishlist",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "format": "prettier --write \"./src/**/*.{js,jsx,css,json}\"",
    "format:check": "prettier --check \"./src/**/*.{js,jsx,css,json}\"",
    "lint": "eslint ./src",
    "lint:fix": "eslint ./src --fix",
    "stylelint": "stylelint \"./src/**/*.css\"",
    "stylelint:fix": "stylelint \"./src/**/*.css\" --fix",
    "check": "npm run format:check && npm run lint && npm run stylelint",
    "fix": "npm run format && npm run lint:fix && npm run stylelint:fix"
  },
  "dependencies": {
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.7.0",
    "prettier": "^3.8.1",
