{
  "name": "wishlist",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "../node_modules/.bin/vite",
    "build": "../node_modules/.bin/vite build",
    "preview": "../node_modules/.bin/vite preview",
    "format": "../node_modules/.bin/prettier --write \"frontend/src/**/*.{js,jsx,css,json}\"",
    "format:check": "../node_modules/.bin/prettier --check \"frontend/src/**/*.{js,jsx,css,json}\"",
    "lint": "../node_modules/.bin/eslint frontend/src",
    "lint:fix": "../node_modules/.bin/eslint frontend/src --fix",
    "stylelint": "../node_modules/.bin/stylelint \"frontend/src/**/*.css\"",
    "stylelint:fix": "../node_modules/.bin/stylelint \"frontend/src/**/*.css\" --fix",
    "check": "npm run format:check && npm run lint && npm run stylelint",
    "fix": "npm run format && npm run lint:fix && npm run stylelint:fix"
  },
  "dependencies": {
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.7.0",
    "prettier": "^3.8.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.14.0",
    "stylelint": "^17.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "eslint": "^9.30.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "vite": "^7.0.4"
  }
}
